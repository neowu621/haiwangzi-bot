// 對應 diving_bot_kit/docs/DIVING_BOT_SPEC.md §3.1 的 8 張表
// 從 Drizzle schema 翻譯過來

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────
enum UserRole {
  customer // 一般會員（用 vipLevel 1-5 表示等級）
  coach // 教練：帶團 + 看當日場次/學員資訊 + 取消/改場次
  boss // 老闆：擁有者（最高，含永久刪除）
  admin // 管理者（老闆代理）：營運全權，但不含系統設定 / 永久刪除
  assistant // v622 助教：看場次/名單 + 點名（不含取消/改場次）
  it // v622 IT：技術全權（= 老闆，含系統設定 + 永久刪除，方便測試）。只能 DB 設定。
}

enum CertLevel {
  OW
  AOW
  Rescue
  DM
  Instructor
}

enum CoachCert {
  DM
  Instructor
  CourseDirector
}

enum Region {
  northeast
  green_island @map("green-island")
  lanyu
  kenting
  other
}

enum Difficulty {
  easy
  medium
  hard
}

enum TripStatus {
  open
  full
  cancelled
  completed
}

enum CancelReason {
  weather
  insufficient
  other
}

enum BookingType {
  daily
  tour
  custom // v475：老闆客製開單（課程 / 1對1 / 體驗等，無對應 trip）
}

enum PaymentStatus {
  pending
  deposit_paid
  fully_paid
  refunding
  refunded
}

enum PaymentMethod {
  cash // 現場支付
  bank // 銀行轉帳
  linepay // LINE Pay
  other
}

enum BookingStatus {
  pending
  awaiting_verify // v276：客戶上傳匯款後，等老闆審核
  confirmed
  cancelled_by_user
  cancelled_by_weather
  cancelled_unpaid // v276：未付款的取消（訂單不成立，不必退款）
  completed
  no_show
}

enum PaymentProofType {
  deposit
  final
  refund
}

enum ReminderChannel {
  line
  email
}

enum MediaPlatform {
  fb
  ig
  yt
  tiktok
  other
}

// ─── Tables ──────────────────────────────────────────────

model User {
  lineUserId                String     @id @map("line_user_id") @db.VarChar(64)
  displayName               String     @map("display_name")
  realName                  String?    @map("real_name")
  phone                     String?    @db.VarChar(32)
  // 註冊 email — 用於通知信、發票、e-card；比 SMS 便宜，首次登入強制要填
  email                     String?    @db.VarChar(254)
  // v256：Email 驗證（點擊驗證信內連結後寫入時間）。null = 尚未驗證
  emailVerifiedAt           DateTime?  @map("email_verified_at") @db.Timestamptz
  // v256：最近一次發送驗證信時間（rate limit 用，60 秒內不能重發）
  emailVerifyTokenSentAt    DateTime?  @map("email_verify_token_sent_at") @db.Timestamptz
  // v257：首單獎勵發放時間（null = 還沒發過）。發放條件：emailVerifiedAt 不為 null + 首筆 fully_paid 訂單
  firstOrderRewardGrantedAt DateTime?  @map("first_order_reward_granted_at") @db.Timestamptz
  // v840：「驗證 Email 拿 50 元」提醒已發送時間（一鍵提醒去重，每人只提醒一次）
  verifyRewardRemindedAt    DateTime?  @map("verify_reward_reminded_at") @db.Timestamptz
  // v311：客戶完成首次 onboarding（必填 realName/phone/email）的時間。null = 還沒完成，所有 LIFF 頁面強制顯示 OnboardingModal
  onboardingCompletedAt     DateTime?  @map("onboarding_completed_at") @db.Timestamptz
  // 通知偏好：客戶可在 /liff/profile 自己關掉。預設都開
  notifyByLine              Boolean    @default(true) @map("notify_by_line")
  notifyByEmail             Boolean    @default(true) @map("notify_by_email")
  emergencyContact          Json?      @map("emergency_contact")
  cert                      CertLevel?
  certNumber                String?    @map("cert_number") @db.VarChar(64)
  // 「總經驗」潛水次數：使用者自填（含其他單位累積，不可驗證）
  logCount                  Int        @default(0) @map("log_count")
  // 「海王子累積」潛水次數：在本系統有 booking 完成（到場勾選）才會 +1
  //   - 教練/老闆按「到場」時 += trip.tankCount × participants
  //   - VIP 等級升等用這個欄位（避免使用者自填灌水）
  haiwangziLogCount         Int        @default(0) @map("haiwangzi_log_count")
  // legacy 單一角色（保留以相容舊資料；新版改用 roles[] 陣列支援多重身分）
  role                      UserRole   @default(customer)
  // 多重角色：一個 user 可同時是 customer + coach + admin
  // 若為空陣列代表還沒遷移，讀的時候會自動 backfill 成 [role]
  roles                     UserRole[] @default([])
  notes                     String?
  // 同伴清單：[{ id, name, phone, cert, certNumber, logCount, relationship }]
  companions                Json       @default("[]")
  // LTV / 黑名單
  noShowCount               Int        @default(0) @map("no_show_count")
  blacklisted               Boolean    @default(false)
  blacklistReason           String?    @map("blacklist_reason")
  // 海王子潛水會員等級 1-5：
  //   1 = 小蝦 Shrimp     (<20 潛 or <10,000)
  //   2 = 龍蝦 Lobster    (21-50 潛 or 10k-30k)
  //   3 = 海龜 SeaTurtle  (51-100 潛 or 30k-80k)
  //   4 = 鬼蝠魟 MantaRay (101-200 潛 or 80k-150k)
  //   5 = 鯨鯊 WhaleShark (>200 潛 or >150k)
  // 0 = 未指派（系統初始或新註冊）
  vipLevel                  Int        @default(1) @map("vip_level")
  // 累計消費 (NT$)：booking.paidAmount 已驗證的總和，會員升等用
  totalSpend                Int        @default(0) @map("total_spend")
  // 生日（年月日）— 用於發放生日禮金（每年自動）
  birthday                  DateTime?  @db.Date
  // 補償金/禮金餘額 (NT$)。來源：生日、VIP 升等、refund 轉禮金、admin 手調
  // 變動皆記錄到 CreditTx 表（audit trail）
  creditBalance             Int        @default(0) @map("credit_balance")
  // 最後一次發放生日禮金的年份，避免同一年發兩次
  birthdayCreditYear        Int?       @map("birthday_credit_year")
  // 網頁管理後台個人密碼（scrypt hash，格式 "salt:hash"）
  // 首次登入時自行設定，之後每次需輸入
  webPasswordHash           String?    @map("web_password_hash")
  // 會員編號 M{YYYYMMDD}-{XX}，XX 為 base-36 2位，首次加入時自動產生
  code                      String?    @unique @map("code") @db.VarChar(12)
  createdAt                 DateTime   @default(now()) @map("created_at") @db.Timestamptz
  lastActiveAt              DateTime   @default(now()) @map("last_active_at") @db.Timestamptz
  // v648：登入紀錄「原子搶位」用 —— 防止 App 載入時多個 /api/me 並發各寫一筆 customer.login
  lastLoginLogAt            DateTime?  @map("last_login_log_at") @db.Timestamptz
  // 軟刪除：設值後使用者無法登入 LIFF，但訂單/付款紀錄保留以便查帳
  // null = 正常會員；DateTime = 已刪除的時間
  deletedAt                 DateTime?  @map("deleted_at") @db.Timestamptz
  deletedBy                 String?    @map("deleted_by") @db.VarChar(64)
  deletedReason             String?    @map("deleted_reason")

  bookings          Booking[]
  diveWishes        DiveWish[] // v318：客製化潛水願望單
  coachProfile      Coach?
  verifiedProofs    PaymentProof[]
  creditTxs         CreditTx[]
  emailVerifyTokens EmailVerifyToken[]
  notifications     Notification[] // 站內訊息通知（第三通道）

  @@map("users")
}

// 站內訊息通知（第三通道）— LINE flex / Email 之外的 App 內通知中心
//   notifyCustomer 觸發時與 LINE/Email 同步寫一筆；預設全開、不受會員 opt-in 控制
//   純文字、零圖片；cursor 分頁載入，未讀數獨立輕端點查詢
model Notification {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @map("user_id") @db.VarChar(64)
  templateKey String    @map("template_key") @db.VarChar(64)
  title       String
  body        String
  linkUrl     String?   @map("link_url")
  // v862：按鈕文字（發送當下從模板複製）。null → 前端顯示預設「前往查看 →」
  buttonLabel String?   @map("button_label") @db.VarChar(64)
  // v858：原 VarChar(16) 只夠放 emoji；改 255 以容納品牌 logo 圖片網址（NotifIcon 會自動判斷）
  icon        String?   @db.VarChar(255)
  isRead      Boolean   @default(false) @map("is_read")
  readAt      DateTime? @map("read_at") @db.Timestamptz
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [lineUserId], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, isRead])
  @@map("notifications")
}

// v473：訊息發送紀錄（唯一的對外訊息發送 log）— LINE / Email / 站內通知 每一筆發送都記一列
model MessageLog {
  id           String   @id @default(uuid()) @db.Uuid
  channel      String   @db.VarChar(8) // line / email / inapp
  templateKey  String   @map("template_key") @db.VarChar(64)
  recipientId  String?  @map("recipient_id") @db.VarChar(64) // 收件人 lineUserId（站內/LINE）
  recipient    String   @db.VarChar(254) // 顯示用：姓名 / email / userId
  title        String   // 主旨 / 標題 / altText
  status       String   @db.VarChar(12) // sent / failed / skipped
  error        String?  @db.Text
  source       String   @default("system") @db.VarChar(32) // notify / test / broadcast / weather / orders ...
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@index([createdAt(sort: Desc)])
  @@index([channel, createdAt(sort: Desc)])
  @@index([status, createdAt(sort: Desc)])
  @@map("message_logs")
}

// v475：合約範本 — 客製訂單的合約類別（OW / AOW / 1對1 / 體驗 / 其他），條款由老闆自行編輯
model ContractTemplate {
  id        String   @id @default(cuid())
  category  String   @unique @db.VarChar(32) // key：ow / aow / oneonone / discover / other
  title     String   @db.VarChar(128)        // 顯示名（OW 開放水域潛水員課程）
  content   String   @db.Text                // 合約條款全文（老闆填，簽署 PDF 會用）
  refUrl    String?  @map("ref_url")         // 課程內容說明連結
  active    Boolean  @default(true)
  sortOrder Int      @default(0) @map("sort_order")
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz
  updatedBy String?  @map("updated_by") @db.VarChar(64)

  @@map("contract_templates")
}

// v256：Email 驗證 token
//   驗證信寄出時建一筆，使用者點 link 後標 usedAt + 寫 User.emailVerifiedAt
//   7 天過期。同一 user 可重發（同一 email 共存的 token 都還能用，但只認最後一個）
model EmailVerifyToken {
  token     String    @id @db.VarChar(64)
  userId    String    @map("user_id") @db.VarChar(64)
  email     String    @db.VarChar(254)
  expiresAt DateTime  @map("expires_at") @db.Timestamptz
  usedAt    DateTime? @map("used_at") @db.Timestamptz
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [lineUserId], onDelete: Cascade)

  @@index([userId])
  @@map("email_verify_tokens")
}

// 補償金 / 禮金 交易紀錄（audit trail）
// amount: 正 = 增加 / 負 = 使用
// reason: birthday / vip_upgrade / refund / used / admin_adjust
model CreditTx {
  id           String    @id @default(uuid()) @db.Uuid
  code         String?   @unique @map("code") @db.VarChar(16) // v225：抵用金編碼 C20260601-XX
  userId       String    @map("user_id") @db.VarChar(64)
  amount       Int // + 增 / - 用
  reason       String    @db.VarChar(32)
  refType      String?   @map("ref_type") @db.VarChar(32) // booking / vip / null
  refId        String?   @map("ref_id")
  note         String?
  // 紀錄事件後的餘額（方便對帳）
  balanceAfter Int       @map("balance_after")
  // v592：批次扣抵「先用最近到期」— 正向發放筆已被用掉/作廢的金額（amount − consumed = 此筆剩餘可用）
  consumedAmount Int     @default(0) @map("consumed_amount")
  createdBy    String?   @map("created_by") @db.VarChar(64) // admin lineUserId
  // 到期日（v184）。null = 永不過期。birthday / 升等獎勵等可設過期
  expiresAt    DateTime? @map("expires_at") @db.Timestamptz
  // v420：到期前提醒已寄出時間（防重複提醒）
  expiryRemindedAt DateTime? @map("expiry_reminded_at") @db.Timestamptz
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [lineUserId], onDelete: Cascade)

  @@index([userId, createdAt])
  // v420：到期提醒 cron 每日掃 expires_at，加索引避免全表掃描
  @@index([expiresAt])
  @@map("credit_txs")
}

model DiveSite {
  id          String     @id @db.VarChar(64)
  name        String
  region      Region
  description String     @default("")
  difficulty  Difficulty @default(medium)
  maxDepth    String     @default("") @map("max_depth") @db.VarChar(32)
  features    String[]   @default([])
  images      String[]   @default([])
  youtubeUrl  String?    @map("youtube_url")
  locationUrl String?    @map("location_url") // Google Maps URL
  cautions    String?
  createdAt   DateTime   @default(now()) @map("created_at") @db.Timestamptz

  @@map("dive_sites")
}

model Coach {
  id         String    @id @db.VarChar(32)
  lineUserId String?   @unique @map("line_user_id") @db.VarChar(64)
  realName   String    @map("real_name")
  cert       CoachCert
  specialty  String[]  @default([])
  // 每一支潛水的教練成本 (NT$/dive)，admin 後台設定，每團排教練後系統可參考
  // 沒有「基本費用」概念，全部都是 per-dive 計算
  feePerDive Int       @default(0) @map("fee_per_dive")
  note       String?
  active     Boolean   @default(true)
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz

  user User? @relation(fields: [lineUserId], references: [lineUserId], onDelete: SetNull)

  @@map("coaches")
}

model DivingTrip {
  id                String        @id @default(uuid()) @db.Uuid
  code              String?       @unique @map("code") @db.VarChar(12)
  date              DateTime      @db.Date
  startTime         String        @map("start_time") @db.VarChar(5)
  isNightDive       Boolean       @default(false) @map("is_night_dive")
  isScooter         Boolean       @default(false) @map("is_scooter")
  // v714：船潛(true)/岸潛(false)。船潛=每人套裝價(extraTank 視為套裝價,不乘支數)
  isBoat            Boolean       @default(false) @map("is_boat")
  diveSiteIds       String[]      @default([]) @map("dive_site_ids")
  tankCount         Int           @default(1) @map("tank_count")
  capacity          Int? // null = 無上限
  coachIds          String[]      @default([]) @map("coach_ids")
  pricing           Json
  // 場次備註說明（顯示在客戶端、教練端、admin 列表）
  notes             String?
  // 集合地點說明（例：海王子潛店 / 龍洞 4 號港 / 潮境停車場...）
  meetingPoint      String?       @map("meeting_point")
  // 集合地點 Google Map URL（與 meetingPoint 分開存）
  meetingPointUrl   String?       @map("meeting_point_url")
  // 潛點參考影片 URL（YouTube / Vimeo 等，給客戶看潛點介紹影片）
  referenceVideoUrl String?       @map("reference_video_url")
  // 場次照片 R2 keys（public bucket，prefix=trips/）
  images            String[]      @default([])
  status            TripStatus    @default(open)
  cancelReason      CancelReason? @map("cancel_reason")
  weatherNote       String?       @map("weather_note")
  // v664：活動提醒事項（針對這一次活動、客戶可見；取代原 Booking.siteNotes/adminNotes）
  activityNote      String?       @map("activity_note") @db.Text
  createdAt         DateTime      @default(now()) @map("created_at") @db.Timestamptz

  @@index([status, date, startTime]) // v356：行事曆/場次列查詢
  @@map("diving_trips")
}

model TourPackage {
  id                  String     @id @default(uuid()) @db.Uuid
  code                String?    @unique @map("code") @db.VarChar(12)
  title               String
  destination         Region
  dateStart           DateTime   @map("date_start") @db.Date
  dateEnd             DateTime   @map("date_end") @db.Date
  itinerary           Json       @default("[]")
  diveSiteIds         String[]   @default([]) @map("dive_site_ids")
  basePrice           Int        @map("base_price")
  deposit             Int
  depositDeadline     DateTime?  @map("deposit_deadline") @db.Timestamptz
  finalDeadline       DateTime?  @map("final_deadline") @db.Timestamptz
  capacity            Int? // null = 無上限
  includes            String[]   @default([])
  excludes            String[]   @default([])
  addons              Json       @default("[]")
  images              String[]   @default([])
  youtubeUrl          String?    @map("youtube_url")
  status              TripStatus @default(open)
  // v186：新增「潛水團行銷頁」用的欄位（對應 mockup）
  subtitle            String? // 副標 / 團別（端午團、中秋團、海之星）
  durationLabel       String?    @map("duration_label") // "4天3夜"
  roomLabel           String?    @map("room_label") // "四人房套房"
  diveStyles          String[]   @default([]) @map("dive_styles") // ["水推","岸潛","船潛","夜潛","沉船潛水"]
  beginnerFriendly    Boolean    @default(false) @map("beginner_friendly")
  tanksCount          Int?       @map("tanks_count") // 總潛水支數
  siteList            String?    @map("site_list") // 潛點清單（每行一個）
  pricingNotes        String?    @map("pricing_notes") // 早鳥/加價說明
  extraNote           String?    @map("extra_note") // 自由備註
  // v347：訂金繳費期限改為「每位客人下訂日 + N 天」(動態，取代固定 depositDeadline 日期)
  depositDueDays      Int        @default(7) @map("deposit_due_days") // 下訂後 N 天內繳訂金
  // 提醒天數設定（開團時可調）
  // 規則：訂金確認後 7 天內付款保留名額；尾款出發前 30 天繳清；行前 2 天再次通知
  depositReminderDays Int        @default(7) @map("deposit_reminder_days") // 訂金截止前 N 天推
  finalReminderDays   Int        @default(30) @map("final_reminder_days") // 尾款截止前 N 天推
  guideReminderDays   Int        @default(2) @map("guide_reminder_days") // 出發前 N 天推手冊
  // v664：活動提醒事項（針對這一團、客戶可見）
  activityNote        String?    @map("activity_note") @db.Text
  createdAt           DateTime   @default(now()) @map("created_at") @db.Timestamptz

  @@index([status, dateStart]) // v356：潛旅列表查詢
  @@map("tour_packages")
}

model Booking {
  id                  String         @id @default(uuid()) @db.Uuid
  code                String?        @unique @map("code") @db.VarChar(12)
  userId              String         @map("user_id") @db.VarChar(64)
  type                BookingType
  // v475：custom（客製開單）沒有對應 trip/tour；refId 改填隨機 UUID（指向不存在的 trip），維持非空避免全專案型別波及
  refId               String         @map("ref_id") @db.Uuid
  participants        Int            @default(1)
  // v704：客戶下單實際選的潛次（每人，1..trip.tankCount）。日潛專用；舊單 null → 顯示時 fallback trip.tankCount
  tankCount           Int?           @map("tank_count")
  // v475：客製訂單欄位（type=custom 時使用）
  customItemName      String?        @map("custom_item_name") @db.VarChar(128) // 品項名（OW課程 / 1對1輔導…）
  customCategory      String?        @map("custom_category") @db.VarChar(32)   // 合約類別 key（對應 ContractTemplate）
  customRefUrl        String?        @map("custom_ref_url")  // 參考連結（課程內容說明）
  contractPdfKey      String?        @map("contract_pdf_key") @db.VarChar(256) // 簽署後合約 PDF（R2 private）
  // 本次參加者明細：[{ name, phone, cert, certNumber, logCount, relationship, isSelf }]
  participantDetails  Json           @default("[]") @map("participant_details")
  selectedAddons      String[]       @default([]) @map("selected_addons")
  rentalGear          Json           @default("[]") @map("rental_gear")
  // v712：下單時凍結的金額明細(氣瓶/減免/裝備/抵用金…→應付),供老闆結帳/核對顯示組成。舊單為 null。
  priceBreakdown      Json?          @map("price_breakdown")
  notes               String? // 客戶備註（客戶預約時填寫）
  siteNotes           String?        @map("site_notes") // 網站備註（管理員填，客戶可見）
  adminNotes          String?        @map("admin_notes") // 管理備註（僅 admin/boss 可見）
  totalAmount         Int            @map("total_amount")
  depositAmount       Int            @default(0) @map("deposit_amount")
  paidAmount          Int            @default(0) @map("paid_amount")
  paymentStatus       PaymentStatus  @default(pending) @map("payment_status")
  // v289：客戶選擇的付款方式（轉帳 / LINE Pay / 其他）。建立訂單時為 null，等客戶到「付款方式選擇」頁才寫入
  paymentMethod       PaymentMethod? @map("payment_method")
  // 「其他」付款方式時客戶填寫的說明（如：街口支付、微信、現金匯款等）
  paymentNote         String?        @map("payment_note")
  // v296：公開付款連結 token（無需 LINE 登入），老闆審核付款後設 verifiedAt 即失效
  payLinkToken        String?        @unique @map("pay_link_token") @db.VarChar(64)
  payLinkVerifiedAt   DateTime?      @map("pay_link_verified_at") @db.Timestamptz
  status              BookingStatus  @default(pending)
  cancellationReason  String?        @map("cancellation_reason")
  refundAmount        Int?           @map("refund_amount")
  refundedAt          DateTime?      @map("refunded_at") @db.Timestamptz
  // 退款方式：cash = 退現金 / credit = 轉成禮金（user.creditBalance）
  refundMethod        String?        @map("refund_method") @db.VarChar(16)
  // v275：退款備註（老闆寫實際退款管道，例：「LINE Pay 訂單 #12345」「匯款到 X 銀行 482324」）
  refundNote          String?        @map("refund_note") @db.Text
  // 預約時使用的禮金（從 user.creditBalance 扣，CreditTx 有對應紀錄）
  // 取消時若 paidAmount>0 系統會自動把這部份退回 creditBalance
  creditUsed          Int            @default(0) @map("credit_used")
  agreedToTermsAt     DateTime       @map("agreed_to_terms_at") @db.Timestamptz
  // v260：手寫簽名（R2 private bucket 的 key，例 signatures/<bookingId>.png）。法律證據長期保留。
  signatureImageKey   String?        @map("signature_image_key") @db.VarChar(256)
  signedAt            DateTime?      @map("signed_at") @db.Timestamptz
  signedFromUserAgent String?        @map("signed_from_user_agent")
  // v612：簽名 DB 暫存 buffer — 下單先存這裡（秒回），背景/cron 再上傳 R2，成功後清空。
  signaturePending    String?        @map("signature_pending") // base64 data URL，上傳 R2 成功後設 null
  signaturePendingAt  DateTime?      @map("signature_pending_at") @db.Timestamptz
  // 超賣標記：booking 接受但容量已滿，提醒教練處理
  overCapacity        Boolean        @default(false) @map("over_capacity")
  // v782：到場確認/五星好評 訊息已推送時間（防一鍵補推重複發；到場點名發送時也蓋章）
  reviewSentAt        DateTime?      @map("review_sent_at") @db.Timestamptz
  createdAt           DateTime       @default(now()) @map("created_at") @db.Timestamptz
  updatedAt           DateTime       @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  user           User            @relation(fields: [userId], references: [lineUserId], onDelete: Restrict)
  paymentProofs  PaymentProof[]
  reminderLogs   ReminderLog[]
  refundRequests RefundRequest[] // v274
  paymentEntries PaymentEntry[] // v366：付款/折抵逐筆明細帳
  emailThreads   EmailThread[] // v521：客服信箱 console（email-console bundle）反向 relation

  // v590：節慶優惠代碼 + 日潛早鳥回饋
  promoCode        String?  @map("promo_code") @db.VarChar(16) // 此訂單使用的優惠代碼
  promoDiscount    Int      @default(0) @map("promo_discount") // 代碼折抵金額 NT$
  earlyBirdCredit  Int      @default(0) @map("early_bird_credit") // 早鳥回饋抵用金(結案後發)
  earlyBirdGranted Boolean  @default(false) @map("early_bird_granted") // 是否已發放

  // v355：效能索引（原本完全沒有，所有 admin/coach/cron 查詢都是 seq scan）
  @@index([refId, type, status]) // by-trip / coach-today / reminders
  @@index([userId, createdAt(sort: Desc)]) // 我的預約 / 會員 LTV
  @@index([type, paymentStatus, status]) // 統計 / 付款 cron
  @@index([status]) // dashboard 計數
  @@index([createdAt(sort: Desc)]) // 全站訂單列表
  @@map("bookings")
}

model PaymentProof {
  id           String           @id @default(uuid()) @db.Uuid
  bookingId    String           @map("booking_id") @db.Uuid
  type         PaymentProofType
  amount       Int
  // v238：照片變 optional（後5碼 + 說明就夠核對）；imageKey 改 nullable
  imageKey     String?          @map("image_key")
  // v379：縮圖 base64（~160px）永遠存 DB → 清單即時顯示、不靠 R2 presign，修「無預覽」+ 加速。
  //   大圖仍走 imageKey（R2 key 優先，R2 不行才退 base64）。
  thumbBase64  String?          @map("thumb_base64") @db.Text
  last5        String?          @map("last5") @db.VarChar(8) // 匯款帳號後 5 碼
  note         String? // 匯款說明（選填）
  uploadedAt   DateTime         @default(now()) @map("uploaded_at") @db.Timestamptz
  verifiedBy   String?          @map("verified_by") @db.VarChar(64)
  verifiedAt   DateTime?        @map("verified_at") @db.Timestamptz
  // v297：駁回保留紀錄而不刪，客戶看得到老闆說明
  rejectedAt   DateTime?        @map("rejected_at") @db.Timestamptz
  rejectReason String?          @map("reject_reason") @db.Text

  booking  Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  verifier User?   @relation(fields: [verifiedBy], references: [lineUserId], onDelete: SetNull)

  @@index([bookingId, uploadedAt(sort: Desc)]) // v356：訂單付款憑證查詢
  @@map("payment_proofs")
}

// v366：付款／折抵逐筆明細帳。
//   每一筆「金額調整」（實收 or 折抵減免）寫一列；Booking.paidAmount 仍為權威加總。
//   amount 正＝增加已付（收款/折抵）；負＝反向沖銷（刪除某筆時補一列）。
//   isCash：true=真的收到現金（轉帳/現金/LINE Pay/抵用金）；false=折抵減免（老闆折抵/助教減免/其他優惠）→ 報表分開算。
model PaymentEntry {
  id            String   @id @default(uuid()) @db.Uuid
  bookingId     String   @map("booking_id") @db.Uuid
  amount        Int // 正=加付款；負=沖銷
  kind          String   @db.VarChar(24) // transfer/cash/linepay/credit/boss_discount/assistant/other/reversal
  isCash        Boolean  @default(true) @map("is_cash")
  note          String?  @db.Text
  createdById   String?  @map("created_by_id") @db.VarChar(64)
  createdByName String?  @map("created_by_name") @db.VarChar(64)
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId, createdAt(sort: Desc)])
  @@map("payment_entries")
}

model ReminderLog {
  id        Int             @id @default(autoincrement())
  bookingId String?         @map("booking_id") @db.Uuid
  type      String
  sentAt    DateTime        @default(now()) @map("sent_at") @db.Timestamptz
  channel   ReminderChannel @default(line)
  error     String?

  booking Booking? @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  // v355：dedup 查詢 findFirst(bookingId+type+channel) 原本是 seq scan
  @@index([bookingId, type, channel])
  @@map("reminder_logs")
}

// v278：訂單狀態歷史（event log）
model BookingStatusLog {
  id         String   @id @default(uuid()) @db.Uuid
  bookingId  String   @map("booking_id") @db.Uuid
  fromStatus String?  @map("from_status") @db.VarChar(32)
  toStatus   String   @map("to_status") @db.VarChar(32)
  actorId    String?  @map("actor_id") @db.VarChar(64) // null = system
  actorRole  String   @map("actor_role") @db.VarChar(16) // customer / coach / admin / boss / system
  note       String?  @db.Text
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@index([bookingId, createdAt])
  @@map("booking_status_logs")
}

// v274：退款申請（兩段式 — admin 發起 → 客戶確認 → 執行）
model RefundRequest {
  id             String    @id @default(uuid()) @db.Uuid
  bookingId      String    @map("booking_id") @db.Uuid
  requestedBy    String    @map("requested_by") @db.VarChar(64) // admin / customer 的 lineUserId
  // v280：誰發起的（customer 客戶自助 / admin 老闆發起給客戶確認）
  initiatedBy    String    @default("admin") @map("initiated_by") @db.VarChar(16)
  method         String    @db.VarChar(16) // "cash" 或 "credit"
  amount         Int // 退款金額 NT$
  creditBonusPct Int       @default(0) @map("credit_bonus_pct") // 抵用金額外加成 %
  reason         String?   @db.Text
  // v275：退款備註（admin 寫實際退款管道，內部用，會 copy 到 booking.refundNote）
  refundNote     String?   @map("refund_note") @db.Text
  // 狀態：
  // pending_customer (admin 發起，等客戶) / accepted (客戶同意) /
  // questioning (客戶有疑問) / executed (已執行) / cancelled (admin 取消申請) /
  // v280：pending_admin (客戶發起，等 admin 審) / rejected_by_admin
  status         String    @default("pending_customer") @db.VarChar(32)
  customerNote   String?   @map("customer_note") @db.Text
  respondedAt    DateTime? @map("responded_at") @db.Timestamptz
  executedAt     DateTime? @map("executed_at") @db.Timestamptz
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@map("refund_requests")
}

// 場次當日照片 — 日潛結束後教練/admin 上傳當天潛水照給客戶下載
// 7 天後 cron 自動刪除（R2 + DB row）
model TripPhoto {
  id            String   @id @default(uuid()) @db.Uuid
  tripId        String   @map("trip_id") @db.Uuid // 對應 DivingTrip
  r2Key         String   @map("r2_key") // R2 public bucket key (prefix=trips/)
  caption       String?
  uploadedBy    String   @map("uploaded_by") @db.VarChar(64) // 教練/admin lineUserId
  uploadedAt    DateTime @default(now()) @map("uploaded_at") @db.Timestamptz
  expiresAt     DateTime @map("expires_at") @db.Timestamptz // uploadedAt + 7 天，cron 到期清
  downloadCount Int      @default(0) @map("download_count")

  @@index([tripId])
  @@index([expiresAt])
  @@map("trip_photos")
}

// 最新動態 / 影像日誌 — 教練在後台貼 FB/IG/YT 連結 + 縮圖，客戶在 /liff/media 看 feed
// 不存實際影片（節流量），只存外部連結 + 小縮圖
model TripMedia {
  id           String        @id @default(uuid()) @db.Uuid
  tripId       String?       @map("trip_id") @db.Uuid // 可選綁定 DivingTrip
  date         DateTime      @db.Date // 拍攝日期
  platform     MediaPlatform
  url          String // FB/IG/YT 原始連結
  thumbnailKey String?       @map("thumbnail_key") // R2 public bucket key
  caption      String?
  createdBy    String?       @map("created_by") @db.VarChar(64) // 教練 lineUserId
  createdAt    DateTime      @default(now()) @map("created_at") @db.Timestamptz

  @@index([date(sort: Desc), createdAt(sort: Desc)]) // v356：媒體列表查詢
  @@map("trip_media")
}

// v318：客製化潛水願望單
// 客戶提出想潛的時間/地點/方式 → 老闆與客戶來回討論 → 老闆確認後開正式場次
model DiveWish {
  id                 String    @id @default(uuid()) @db.Uuid
  // v328：願望單編號 W20260605-XX
  code               String?   @unique @map("code") @db.VarChar(12)
  userId             String    @map("user_id") @db.VarChar(64)
  // 願望內容
  type               String    @db.VarChar(16) // "boat" 船潛 / "shore" 岸潛 / "night" 夜潛 / "tour" 潛水團
  preferredDate      DateTime  @map("preferred_date") @db.Date
  // 備選日期: ["YYYY-MM-DD", ...]
  alternativeDates   Json      @default("[]") @map("alternative_dates")
  // 標準潛點 id: ["龍洞", "鼻頭", ...]
  diveSiteIds        Json      @default("[]") @map("dive_site_ids")
  // 客戶自填的「其他潛點」（如：綠島、墾丁）
  otherSites         String?   @map("other_sites")
  participants       Int       @default(1)
  budgetPerPerson    Int?      @map("budget_per_person")
  customerNote       String?   @map("customer_note") @db.Text
  // 參考圖片: [{ url, key?, type: "r2"|"link", caption? }]
  referenceImages    Json      @default("[]") @map("reference_images")
  // 討論串: [{ from: "customer"|"boss", text, at: ISO string, actorId, attachments? }]
  messages           Json      @default("[]")
  // 狀態
  status             String    @default("pending") @db.VarChar(16) // pending / discussing / converted / cancelled
  cancelledBy        String?   @map("cancelled_by") @db.VarChar(16) // customer / boss / system (7天自動)
  cancellationReason String?   @map("cancellation_reason") @db.Text
  // 7 天無互動自動關閉
  lastActivityAt     DateTime  @default(now()) @map("last_activity_at") @db.Timestamptz
  // 轉成正式場次
  convertedTripId    String?   @map("converted_trip_id") @db.Uuid
  convertedTourId    String?   @map("converted_tour_id") @db.Uuid
  convertedAt        DateTime? @map("converted_at") @db.Timestamptz
  cancelledAt        DateTime? @map("cancelled_at") @db.Timestamptz
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [lineUserId], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([lastActivityAt])
  @@map("dive_wishes")
}

// 首頁 / 全站設定 — Admin 在 /liff/admin/site-config 可改
// 單列表（id 固定 "default"），方便 upsert
model SiteConfig {
  id String @id @default("default") @db.VarChar(32)

  // Hero
  heroTitle    String @default("東 北 角 海 王 子") @map("hero_title")
  heroSubtitle String @default("NEIL OCEAN PRINCE") @map("hero_subtitle")
  heroGreeting String @default("嗨") @map("hero_greeting")

  // 6 卡 — 整段 JSON array
  // [{id, label, enLabel, desc, href, external, icon, accent, enabled, order}]
  cards Json @default("[]")

  // 海況卡
  seaEnabled  Boolean @default(true) @map("sea_enabled")
  seaTitle    String  @default("明日海況沉穩 · 適合下水") @map("sea_title")
  seaInfo     String  @default("北風 3 級｜浪高 1m｜水溫 24°C｜能見度 8-12m") @map("sea_info")
  seaCtaLabel String? @default("查看明日場次") @map("sea_cta_label")
  seaCtaHref  String? @default("/liff/calendar") @map("sea_cta_href")

  // Footer slogan
  footerSloganZh String @default("探索海洋 · 安全潛水 · 專業教學") @map("footer_slogan_zh")
  footerSloganEn String @default("EXPLORE THE OCEAN") @map("footer_slogan_en")

  // Splash
  splashEnabled    Boolean @default(true) @map("splash_enabled")
  splashDurationMs Int     @default(3000) @map("splash_duration_ms")
  splashCooldownMs Int     @default(3600000) @map("splash_cooldown_ms") // 1 hour

  // 天氣自動取消開關
  // false (預設安全)：cron 偵測風速超標 → 只推警告給教練 LINE，不動 DB，等教練手動確認
  // true：cron 直接 cancel + 推通知給所有客戶（舊行為）
  weatherAutoCancel Boolean @default(false) @map("weather_auto_cancel")

  // 5 等級會員設定（JSON array of VipTier objects）
  // 結構：[{level, key, name, enName, emoji, minLogs, minSpend, benefits[], color}, ...]
  // 空陣列 = 使用 src/lib/vip-tier.ts 內建預設
  vipTiers Json @default("[]") @map("vip_tiers")

  // 補償金 / 禮金 規則
  // 生日當天自動發放金額 (NT$)。設 0 = 關閉
  birthdayCreditAmount       Int  @default(100) @map("birthday_credit_amount")
  // 生日禮金有效天數（v184）。0 = 永不過期
  birthdayCreditExpiryDays   Int  @default(360) @map("birthday_credit_expiry_days")
  // v185: VIP 升等獎勵禮金有效天數
  vipUpgradeCreditExpiryDays Int  @default(360) @map("vip_upgrade_credit_expiry_days")
  // v185: admin 手動發放禮金的預設有效天數（可在發放時覆寫）
  adminGrantCreditExpiryDays Int  @default(360) @map("admin_grant_credit_expiry_days")
  // v185: 退款轉禮金 有效天數（0 = 永不過期，退款通常不限期）
  refundCreditExpiryDays     Int  @default(0) @map("refund_credit_expiry_days")
  // VIP 升等獎金：{ "2": 200, "3": 500, "4": 1000, "5": 2000 } — key=升到的等級
  vipUpgradeCredits          Json @default("{}") @map("vip_upgrade_credits")

  // 可配置金額設定
  // 外部連結（Rich Menu / LIFF 用）— admin 後台可編輯
  // { fbGroupUrl, mediaUrl, youtubeChannelUrl, instagramUrl }
  externalLinks        Json   @default("{}") @map("external_links")
  gearRentalPrices     Json   @default("{}") @map("gear_rental_prices")
  // {"BCD":200,"regulator":200,"wetsuit":300,"fins":100,"mask":100,"computer":300,"full_set":800}
  defaultTripPricing   Json   @default("{}") @map("default_trip_pricing")
  // {"baseTrip":1200,"extraTank":500,"nightDive":300,"scooterRental":500}
  defaultCoachFee      Int    @default(1500) @map("default_coach_fee")
  weatherWindThreshold Int    @default(10) @map("weather_wind_threshold")
  // 付款資訊（銀行 + LINE Pay）— v160 起改用 DB 管理
  // { bank: {name, branch, account, holder}, linepay: {qrUrl, liteId} }
  paymentInfo          Json   @default("{}") @map("payment_info")
  // v764：網站 AI 客服小幫手後台設定（單一 JSON）
  //   { enabled, model, persona, greeting, extraKnowledge }
  aiBot                Json   @default("{}") @map("ai_bot")
  // v227：取消政策（admin 可編輯，FAQ + 預約頁同步顯示）
  cancellationPolicy   String @default("") @map("cancellation_policy") @db.Text
  // v257：安全政策（admin 可編輯，FAQ + 預約頁同步顯示）
  safetyPolicy         String @default("") @map("safety_policy") @db.Text

  // v261：首單付款完成 + Email 已驗證 → 自動發抵用金（0 = 停用此功能）
  firstOrderRewardAmount     Int @default(100) @map("first_order_reward_amount")
  firstOrderRewardExpiryDays Int @default(360) @map("first_order_reward_expiry_days")

  // v519：訊息模板「提前幾天通知」全域設定 — 由訊息模板頁可調，對應原本寫死在 cron 的常數
  d1ReminderLeadDays      Int @default(1)  @map("d1_reminder_lead_days")       // 日潛行前提醒：場次前 N 天
  finalEarlyLeadDays      Int @default(33) @map("final_early_lead_days")       // 潛旅尾款預告：出發前 N 天
  depositRemindBeforeDays Int @default(2)  @map("deposit_remind_before_days")  // 潛旅訂金催繳：繳費截止前 N 天
  creditExpiryLeadDays    Int @default(7)  @map("credit_expiry_lead_days")     // 抵用金到期提醒：到期前 N 天

  // v388：註冊禮金（Email 驗證通過後發；0 = 停用）
  signupRewardAmount     Int @default(50) @map("signup_reward_amount")
  signupRewardExpiryDays Int @default(0) @map("signup_reward_expiry_days") // 0 = 永不過期
  // v388：VIP5 滿級後每 N 潛回饋 M 元抵用金（0 = 停用）
  vipOverflowDives       Int @default(50) @map("vip_overflow_dives")
  vipOverflowCredit      Int @default(1000) @map("vip_overflow_credit")

  // v264：自動發送設定
  //   每日天氣回報（Cronicle 觸發）
  dailyWeatherReportEnabled    Boolean   @default(false) @map("daily_weather_report_enabled")
  // recipients: ["line:Uxxx", "email:xxx@yy.com", ...]
  dailyWeatherReportRecipients Json      @default("[]") @map("daily_weather_report_recipients")
  dailyWeatherReportLastSentAt DateTime? @map("daily_weather_report_last_sent_at") @db.Timestamptz
  // v389：發送時段（台灣時間，僅供 UI 產生 Cronicle UTC cron + 顯示），格式 [{"h":22,"m":0},{"h":5,"m":0}]
  weatherReportSlots           Json      @default("[{\"h\":22,\"m\":0},{\"h\":5,\"m\":0}]") @map("weather_report_slots")
  // v389：發送內容開關，格式 {"wind":true,"temp":true,"sessions":true,"wave":false}
  weatherReportContent         Json      @default("{\"wind\":true,\"temp\":true,\"sessions\":true,\"wave\":false}") @map("weather_report_content")
  // v411：海象（CWA O-B0075-001 浮標+潮位）整合進每日天氣回報
  weatherMarineEnabled         Boolean   @default(false) @map("weather_marine_enabled")
  // 回報點：[{label,buoyId,tideId}]，預設 龍洞區 + 基隆區
  weatherMarinePoints          Json      @default("[{\"label\":\"龍洞區\",\"buoyId\":\"46694A\",\"tideId\":\"C4A02\"},{\"label\":\"基隆區\",\"buoyId\":\"C6B01\",\"tideId\":\"C4B01\"}]") @map("weather_marine_points")
  // 欄位開關 {waveHeight,waveDir,wavePeriod,seaTemp,current,tide}
  weatherMarineFields          Json      @default("{\"waveHeight\":true,\"waveDir\":true,\"wavePeriod\":true,\"seaTemp\":true,\"current\":true,\"tide\":true}") @map("weather_marine_fields")

  // v315：每日訂單日報（早 07:00 由 Cronicle 觸發）
  dailyBriefingEnabled        Boolean   @default(true) @map("daily_briefing_enabled")
  // 是否也發給有 coach 角色的人（教練版只列場次+客戶，不含金額）
  dailyBriefingIncludeCoaches Boolean   @default(true) @map("daily_briefing_include_coaches")
  dailyBriefingLastSentAt     DateTime? @map("daily_briefing_last_sent_at") @db.Timestamptz
  // v855：訂單預報收件人與管道 ["line:Uxxx","inapp:Uxxx","email:xx@yy.com"]；空=沿用舊行為(自動抓 boss/admin，LINE+Email)
  dailyBriefingRecipients     Json      @default("[]") @map("daily_briefing_recipients")

  // v391：場次 Dump 自動優惠開頭（開關 + 可編輯文案）
  dumpPromoEnabled Boolean @default(false) @map("dump_promo_enabled")
  dumpPromoText    String  @default("") @map("dump_promo_text")

  // v891：場次 Dump 結尾聯繫／資訊（開關 + 可編輯文案；留空用系統預設）
  dumpFooterEnabled Boolean @default(true) @map("dump_footer_enabled")
  dumpFooterText    String  @default("") @map("dump_footer_text")

  // v895：FB 貼文版專屬 hashtag（一行，空格分隔；清空 = 不放 hashtag）
  dumpFbHashtags String @default("#東北角潛水 #828魚群風暴潛水 #子彈流鶯歌石潛水 #海王子潛水團 #水肺潛水 #潛水預約 #潛旅") @map("dump_fb_hashtags")

  // v897：日潛場次「快速範本」（固定潛點的預填值，JSON 陣列）
  tripTemplates Json @default("[]") @map("trip_templates")

  // v403：首頁「最新動態」影片清單 + 模式
  // homeVideosMode: "curated" 用 homeVideos JSON；"auto" 改打 /api/youtube/recent
  // homeVideos: [{id, title, isShort}]
  homeVideosMode String @default("curated") @map("home_videos_mode") @db.VarChar(16)
  homeVideos     Json   @default("[]") @map("home_videos")
  // v406：最新動態進階 — 精選置頂ID / 顯示數量 / 排除清單 / 長片濾鏡(all|long)
  homeVideoFeaturedId String @default("")    @map("home_video_featured_id") @db.VarChar(32)
  homeVideoCount      Int    @default(5)     @map("home_video_count")
  homeVideoExcludeIds Json   @default("[]")  @map("home_video_exclude_ids")
  homeVideoFilter     String @default("all") @map("home_video_filter") @db.VarChar(8)

  // v409/v414：首頁「學員怎麼說」（後台可編輯）。第 1 則為主打長文卡。
  //   [{ name, avatar, activity, title, text }]  avatar 為圖片 URL/上傳 data URL（空字串則顯示首字色塊）
  homeTestimonials Json @default("[]") @map("home_testimonials")
  // v414：學員怎麼說區塊底部「總結語」
  homeReviewsNote  String @default("") @map("home_reviews_note")

  // v392：氣瓶限時折扣（自動套用；每支氣瓶折抵 NT$，可設理由 + 起訖日）
  tankPromoEnabled  Boolean   @default(false) @map("tank_promo_enabled")
  tankPromoDiscount Int       @default(0) @map("tank_promo_discount")
  tankPromoReason   String    @default("") @map("tank_promo_reason")
  tankPromoStart    DateTime? @map("tank_promo_start") @db.Timestamptz
  tankPromoEnd      DateTime? @map("tank_promo_end") @db.Timestamptz

  // v638：教練/助教 氣瓶優惠價（固定每支價；下單者 roles 含 coach/assistant 時，
  //        氣瓶單價改用此價，且獨佔——不疊氣瓶限時折扣/優惠代碼/早鳥；抵用金仍可折。只適用日潛。）
  staffTankEnabled Boolean @default(false) @map("staff_tank_enabled")
  staffTankPrice   Int     @default(0) @map("staff_tank_price") // 固定每支氣瓶價 NT$

  // v650：群發「已儲存訊息模組」（命名草稿，不含發送對象）
  //  [{ id, name, channel, template, altText, text, emailSubject, emailBody, params, createdAt }]
  broadcastPresets Json @default("[]") @map("broadcast_presets")

  // v590：日潛早鳥回饋（提早預約、滿額、結案後送抵用金；越早送越多）
  earlyBirdEnabled   Boolean @default(false) @map("early_bird_enabled")
  earlyBirdMinAmount Int     @default(1000) @map("early_bird_min_amount") // 最低消費門檻
  earlyBirdTiers     Json    @default("[]") @map("early_bird_tiers") // [{weeks:3,credit:50},{weeks:4,credit:100}]

  // v470：Email 發送路徑 — gmail（預設）/ zsend / fallback（Gmail 失敗自動改 ZSend）
  emailProvider String @default("gmail") @map("email_provider") @db.VarChar(16)

  // v610：抵用金異動通知通道（預設 Email + 站內，LINE 預設關）
  creditNotifyLine  Boolean @default(false) @map("credit_notify_line")
  creditNotifyEmail Boolean @default(true)  @map("credit_notify_email")
  creditNotifyInApp Boolean @default(true)  @map("credit_notify_inapp")

  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz
  updatedBy String?  @map("updated_by") @db.VarChar(64)

  @@map("site_config")
}

// 訊息模板覆寫 — admin 可在後台改各個 Flex 模板的標題/副標/按鈕文字
// key 對應 src/lib/flex/index.ts 的 FLEX_TEMPLATE_LABELS
model MessageTemplate {
  key          String   @id @db.VarChar(64)
  title        String?
  subtitle     String?
  bodyText     String?  @map("body_text")
  buttonLabel  String?  @map("button_label")
  buttonUrl    String?  @map("button_url") // v792：按鈕點擊連結（後台可編輯，如到場確認的 Google 評論網址）
  button2Label String?  @map("button2_label") // v834：第二顆按鈕文字（到場確認的「私訊反映」）
  altText      String?  @map("alt_text")
  footerHint   String?  @map("footer_hint") // v480
  // v196：管道開關（null = 用 template 預設）
  lineEnabled  Boolean? @map("line_enabled")
  emailEnabled Boolean? @map("email_enabled")
  // 站內訊息通知（第三通道）開關（null = 用 template 預設 defaultInApp）
  inAppEnabled Boolean? @map("in_app_enabled")
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz
  updatedBy    String?  @map("updated_by") @db.VarChar(64)

  @@map("message_templates")
}

// 操作紀錄 — 所有後台操作皆會記錄
model AuditLog {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  // 操作者
  actorId        String? @map("actor_id") @db.VarChar(64) // lineUserId 或 "system"
  actorName      String? @map("actor_name") @db.VarChar(128)
  // v334：操作者角色（customer / admin / boss / system）+ IP + UA
  actorRole      String? @map("actor_role") @db.VarChar(16)
  actorIp        String? @map("actor_ip") @db.VarChar(64)
  actorUserAgent String? @map("actor_user_agent") @db.Text

  // 操作類型：auth.login / booking.update / trip.create / config.update / customer.xxx 等
  action String @db.VarChar(64)

  // 對象
  targetType  String? @map("target_type") @db.VarChar(32) // booking / trip / user / config ...
  targetId    String? @map("target_id") @db.VarChar(64)
  targetLabel String? @map("target_label") @db.VarChar(256) // 顯示用標籤

  // 附加資料（前後值、操作詳情等）
  metadata Json?

  @@index([actorId])
  @@index([action])
  @@index([actorRole])
  @@index([createdAt(sort: Desc)])
  // v355：前台活動 / 操作紀錄常用複合查詢（actorRole/actorId + 時間倒序）
  @@index([actorRole, createdAt(sort: Desc)])
  @@index([actorId, createdAt(sort: Desc)])
  @@map("audit_log")
}

// 最新動態（manual 由 admin 後台手動 post，或 future 由 cron 自動抓 YouTube/IG）
model MediaPost {
  id          String   @id @default(uuid()) @db.Uuid
  // 來源：manual / youtube / facebook / instagram ...（未來自動抓用）
  source      String   @db.VarChar(16)
  // 自動抓時用，例如 YT video ID，用於 upsert 去重；手動 post 為 null
  externalId  String?  @map("external_id") @db.VarChar(128)
  title       String
  description String?
  imageUrl    String?  @map("image_url")
  linkUrl     String   @map("link_url")
  publishedAt DateTime @map("published_at") @db.Timestamptz
  visible     Boolean  @default(true)
  pinned      Boolean  @default(false)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@index([visible, publishedAt(sort: Desc)])
  @@index([source, externalId])
  @@map("media_posts")
}

// 客戶瀏覽紀錄（用於「看過但沒下單」高意願客戶分析）
model PageView {
  id       String   @id @default(cuid())
  userId   String   @map("user_id") @db.VarChar(64)
  refType  String   @map("ref_type") @db.VarChar(16) // "trip" | "tour"
  refId    String   @map("ref_id") @db.VarChar(64)
  viewedAt DateTime @default(now()) @map("viewed_at") @db.Timestamptz

  @@index([userId, viewedAt(sort: Desc)])
  @@index([refType, refId, viewedAt(sort: Desc)])
  @@map("page_views")
}

// ─────────────────────────────────────────────────────────────
// v521：客服信箱 Console（haiwangzi-email-console bundle）
//   service@haiwangzi.xyz 對外 · Zeabur Email 寄信 · Inbound webhook 收信
//   來源：prisma/schema.email.prisma（合併進來，未覆蓋原檔）
//   調整：bookingId 改 @db.Uuid 以對齊 Booking.id 的 @db.Uuid 型別
// ─────────────────────────────────────────────────────────────
model EmailThread {
  id            String         @id @default(cuid())
  subject       String
  customerEmail String         @map("customer_email")
  customerName  String?        @map("customer_name")
  // v561：通道(email / line);LINE 對話用 lineUserId 當識別
  channel       String         @default("email")
  lineUserId    String?        @map("line_user_id")
  status        ThreadStatus   @default(WAITING)
  tags          String[]       @default([])
  assignee      String? // "汪汪" / "Neo"
  bookingId     String?        @map("booking_id") @db.Uuid
  booking       Booking?       @relation(fields: [bookingId], references: [id])
  lastMessageAt DateTime       @default(now()) @map("last_message_at")
  messages      EmailMessage[]
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  @@index([status, lastMessageAt])
  @@index([customerEmail])
  @@map("email_threads")
}

model EmailMessage {
  id       String      @id @default(cuid())
  threadId String      @map("thread_id")
  thread   EmailThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  direction Direction
  channel   String  @default("email") // v561：email / line
  fromAddr  String  @map("from_addr")
  toAddr    String  @map("to_addr")
  ccAddr    String? @map("cc_addr")
  subject   String
  bodyText  String? @map("body_text") @db.Text
  bodyHtml  String? @map("body_html") @db.Text

  // RFC 標頭 — threading 與去重的關鍵
  messageId  String  @unique @map("message_id")
  inReplyTo  String? @map("in_reply_to")
  references String?

  providerId  String?       @map("provider_id") // Zeabur Email / Postmark 回傳的 ID
  status      MessageStatus @default(RECEIVED)
  attachments Json? // [{ filename, contentType, size, key, bucket }]

  // v521：engagement 追蹤（Zeabur open/click webhook 寫入）
  openedAt  DateTime? @map("opened_at")
  clickedAt DateTime? @map("clicked_at")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([threadId, createdAt])
  @@index([providerId])
  @@map("email_messages")
}

// 被退信/投訴的地址，避免再寄（保護網域信譽）
model SuppressedEmail {
  email     String   @id
  reason    String // "bounce" | "complaint"
  createdAt DateTime @default(now()) @map("created_at")

  @@map("suppressed_emails")
}

// v531：收信紀錄 — 每次讀 Gmail（手動/排程）記一筆：時間、收到幾封
model EmailPollLog {
  id       String   @id @default(cuid())
  trigger  String // "cron" | "manual"
  scanned  Int      @default(0)
  ingested Int      @default(0)
  dedup    Int      @default(0)
  skipped  Int      @default(0)
  ok       Boolean  @default(true)
  error    String?
  ranAt    DateTime @default(now()) @map("ran_at")

  @@index([ranAt(sort: Desc)])
  @@map("email_poll_logs")
}

// v532：已刪除訊息墓碑 — 後台刪掉的信，記住其 Message-ID，避免下次收信又被當新信收回來
model EmailDeletedMsgId {
  messageId String   @id @map("message_id")
  deletedAt DateTime @default(now()) @map("deleted_at")

  @@map("email_deleted_msgids")
}

// v577：每日訪客計數（隱私友善）— 只存「每天總數」聚合，不存任何訪客身分 / 不放 cookie。
//   views    = 當天頁面開啟次數（每次全頁載入 +1，/admin 後台不計）
//   visitors = 當天「新訪客」數（同一瀏覽器當天第一次開才 +1，靠 localStorage 旗標判斷）
model DailyStat {
  date      String   @id @db.VarChar(10) // YYYY-MM-DD（Asia/Taipei）
  views     Int      @default(0)
  visitors  Int      @default(0)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@map("daily_stats")
}

// v584：每小時訪客計數（給後台「近 24 小時」活動圖）。hour = "YYYY-MM-DD HH"（Asia/Taipei）。
model HourlyStat {
  hour      String   @id @db.VarChar(13) // "YYYY-MM-DD HH"（Asia/Taipei）
  views     Int      @default(0)
  visitors  Int      @default(0)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@map("hourly_stats")
}

// v590：節慶優惠代碼（下單輸入；取其優、可疊抵用金）。
//   discountType: "per_tank"(每支氣瓶折 NT$) / "percent"(訂單折 %)。
//   isPublic: 公開(秀給客戶+一鍵套用) / 私密(只有拿到碼的人能用)。
//   appliesTo: "daily" / "tour" / "both"。
model PromoCode {
  id            String   @id @default(cuid())
  title         String                              // 主題
  code          String   @unique @db.VarChar(16)    // 7 碼英數(系統自動產生)
  discountType  String   @db.VarChar(12)            // per_tank | percent
  discountValue Int                                 // NT$/支 或 百分比
  startAt       DateTime @db.Timestamptz
  endAt         DateTime @db.Timestamptz
  isPublic      Boolean  @default(true)
  appliesTo     String   @default("daily") @db.VarChar(8)
  minAmount     Int      @default(0)                // 滿額才折(0=不限)
  perUserLimit  Int      @default(0)                // 每人限用(0=不限)
  totalLimit    Int      @default(0)                // 總量上限(0=不限)
  usedCount     Int      @default(0)
  audienceTag   String?  @db.VarChar(24)            // 限定客群(如 vip5);null=不限
  enabled       Boolean  @default(true)
  note          String   @default("")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([code])
  @@map("promo_codes")
}

// v580：Google OAuth 連線（目前用於 GA4 Data API 唯讀）。provider="ga"。
//   refreshToken 是長期憑證 → 後台用它換 access token 拉 GA 數據（analytics.readonly）。
//   只有老闆/管理者能連接；存於自家 DB（非 repo）。
model GoogleOAuth {
  provider     String   @id // "ga"
  refreshToken String   @map("refresh_token")
  propertyId   String?  @map("property_id") // GA4 數字資源 ID
  connectedBy  String?  @map("connected_by")
  connectedAt  DateTime @default(now()) @map("connected_at") @db.Timestamptz

  @@map("google_oauth")
}

enum ThreadStatus {
  WAITING // 待回覆
  PROCESSING // 處理中
  CLOSED // 已結案
}

enum Direction {
  INBOUND
  OUTBOUND
}

enum MessageStatus {
  RECEIVED // 收進來的信
  QUEUED // 已排入 Zeabur Email
  SENT // SES 已收下
  DELIVERED // 對方已收到
  BOUNCED // 退信
  FAILED // 拒絕/送不出
}
