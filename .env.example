# ─────────────────────────────────────────────
# LINE Messaging API + LIFF
# ─────────────────────────────────────────────
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=
LINE_LIFF_ID=
NEXT_PUBLIC_LIFF_ID=
# (選) idToken audience 驗證
LINE_LIFF_CHANNEL_ID=

# ─────────────────────────────────────────────
# JWT / Cron secret (請用 32+ 字元亂數,可用 `openssl rand -hex 32` 產)
#   CRON_SECRET：給 /api/cron/reminders 認證用 (Authorization: Bearer <secret>)
#   Cronicle (https://neowu-cron-hub.zeabur.app) 端設環境變數 HAIWANGZI_CRON_SECRET
#   兩邊值必須一致
# ─────────────────────────────────────────────
JWT_SECRET=
CRON_SECRET=

# ─────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────
# 本機: docker compose up -d 後用這條
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/haiwangzi
# Zeabur: 換成 postgresql://root:<password>@<host>:<port>/zeabur

# ─────────────────────────────────────────────
# Cloudflare R2 — 雙 bucket 模型
#   public : 潛點照片 / Rich Menu / 頭像  (對外可看)
#   private: 轉帳截圖 / 敏感檔             (presigned GET 才看得到)
# ─────────────────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=
R2_PUBLIC_BUCKET=haiwangzi-public
R2_PRIVATE_BUCKET=haiwangzi-private
R2_PUBLIC_URL=

# ─────────────────────────────────────────────
# 匯款資訊 (顯示於付款頁與訂金通知 Flex)
# ─────────────────────────────────────────────
BANK_NAME=
BANK_BRANCH=
BANK_ACCOUNT=
BANK_HOLDER=

# ─────────────────────────────────────────────
# Email (Gmail SMTP + App Password)
#
# 1. 開兩階段驗證: https://myaccount.google.com/security
# 2. 產 App Password:  https://myaccount.google.com/apppasswords
#    選 "Mail" + "Other (custom name)" → 拿到 16 字密碼 (例 "abcd efgh ijkl mnop")
# 3. 兩個值填進 Zeabur env vars (本檔不要存實際值)
#
# Gmail 限額: 個人 500 封/天、Workspace 2000 封/天，超過會被擋
# 若量大要改 SendGrid / Resend / AWS SES
# ─────────────────────────────────────────────
GMAIL_USER=
GMAIL_APP_PASSWORD=
# (選) 自訂顯示寄件人，預設 "海王子潛水團 <GMAIL_USER>"
EMAIL_FROM=
# (選) 回信地址，預設同 GMAIL_USER
EMAIL_REPLY_TO=

# ─────────────────────────────────────────────
# App
# ─────────────────────────────────────────────
NODE_ENV=development
PORT=3000
NEXT_PUBLIC_APP_NAME=東北角海王子潛水團
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# LINE OA 相關（換廠商時必填）
NEXT_PUBLIC_LINE_OA_ID=@your-line-oa-id
NEXT_PUBLIC_LINE_ADD_FRIEND_URL=https://line.me/R/ti/p/@your-line-oa-id

# App 顯示（換廠商時必填）
NEXT_PUBLIC_APP_TAGLINE=安全．專業．陪你看見海
APP_DEFAULT_REGION=東北角

# Dev/CI 桌面測試: 設 1 走 mock profile 跳過真 LIFF init
NEXT_PUBLIC_LIFF_MOCK=0

# ─────────────────────────────────────────────
# Admin Web 後台（v167+ 新增）
# ─────────────────────────────────────────────
# admin/boss 首次登入或忘記密碼時，用此 secret 重設密碼（POST /api/admin-web/set-password）
ADMIN_WEB_SECRET=

# 系統錯誤 + 每日結算提醒會 LINE 推播給這些 lineUserId（用逗號分隔）
ADMIN_LINE_USER_IDS=

# ─────────────────────────────────────────────
# 中央氣象署 API (cron weather-check 用)
# ─────────────────────────────────────────────
# 申請：https://opendata.cwa.gov.tw/userLogin
CWA_API_KEY=
# 監測站清單，逗號分隔（預設用龍洞）
WEATHER_STATIONS=
# 風速門檻 m/s（也可在後台「系統設定」設，這個是 fallback）
WEATHER_WIND_THRESHOLD=10

# ─────────────────────────────────────────────
# Sentry 錯誤追蹤（選填）
# ─────────────────────────────────────────────
SENTRY_DSN=

# ─────────────────────────────────────────────
# Dev / Demo 模式（production 一律設 false / 不設）
# ─────────────────────────────────────────────
# 啟用後 ?lineUserId=xxx 即可冒充任何使用者（極度危險，僅限本機）
DEV_MODE_ENABLED=
# Dev 預設冒充的 lineUserId
NEXT_PUBLIC_MOCK_USER_ID=
NEXT_PUBLIC_DEV_MODE=
# 環境標籤 (DEV/LOCAL/STAGING/DEMO)，顯示在頁面頂部色條
NEXT_PUBLIC_APP_LABEL=
# Demo 環境啟用每日 reset（cron 用），production 不可設 1
RESET_DEMO_DAILY=

# ─────────────────────────────────────────────
# R2 兼容變數（與 R2_PUBLIC_BUCKET / R2_PUBLIC_URL 二選一即可）
# ─────────────────────────────────────────────
NEXT_PUBLIC_R2_PUBLIC_BASE=
R2_BUCKET=
